# Copy to .env and fill in your own values. .env is gitignored.
# All fastlane lanes below (ios/macos/macos_se) read these via ENV.fetch,
# so a missing variable fails fast instead of silently signing with the wrong
# identity.

# App Store Connect API key.
# The .p8 file goes at each platform's fastlane/AuthKey.p8 (gitignored).
FASTLANE_ASC_KEY_ID=
FASTLANE_ASC_ISSUER_ID=

# Full certificate subjects, as shown in Keychain Access.
# Only needed when running the MAS lane (macos/) / Developer ID lane (macos_se/).
FASTLANE_MAS_INSTALLER_CERT="3rd Party Mac Developer Installer: Your Company (XXXXXXXXXX)"
FASTLANE_DEVELOPER_ID_CERT="Developer ID Application: Your Company (XXXXXXXXXX)"

# AdMob production IDs. Leave empty to have release builds fall back to
# Google's public test ads/App IDs — app will still run, but with test ads.
#
# APP IDs (consumed by Android's AndroidManifest.xml / iOS Info.plist via
# manifestPlaceholders + $(ADMOB_APP_ID_IOS) xcconfig substitution):
ADMOB_APP_ID_ANDROID=
ADMOB_APP_ID_IOS=

# Ad Unit IDs (forwarded by build_scripts/app/flutter.py as `--dart-define`;
# picked up via String.fromEnvironment):
ADMOB_AD_UNIT_ID_ANDROID=
ADMOB_AD_UNIT_ID_IOS=
